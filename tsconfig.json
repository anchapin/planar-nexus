{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "src/lib/**/*.{ts,tsx}",
    "src/app/**/*.{ts,tsx}",
    "src/ai/**/*.{ts,tsx}",
    "src/hooks/**/*.{ts,tsx}",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src-tauri/target",
    "e2e",
    "scripts",
    "**/__tests__"
  ]
}