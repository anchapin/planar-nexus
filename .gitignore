# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# This repo is npm-only (`package-lock.json` + `npm ci`). pnpm-lock.yaml is
# stale/unused and must not be re-introduced (issue #1496).
pnpm-lock.yaml

# Virtual environments
venv/
.venv/

# testing
/coverage
/test-results

# mutation testing (Stryker) — issue #1097
/.stryker-tmp
/reports/mutation

# playwright
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
# Tauri updater signing keys (issue #1403). The PRIVATE key must NEVER be
# committed — only the PUBLIC .pub counterpart belongs in the repo (as the
# value of src-tauri/tauri.conf.json `plugins.updater.pubkey`). The CI
# pipeline reads the private key from the TAURI_SIGNING_PRIVATE_KEY secret.
*.key
*.key.pub
.tauri/
src-tauri/target/
src-tauri/gen/
*.json
# i18n message catalogs must be tracked
!src/messages/*.json

# python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
nohup.out

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.genkit/*
.env*

# firebase
firebase-debug.log
firestore-debug.log

# backup files
*.bak
*.backup
*.orig

# Claude Code worktrees — these must live OUTSIDE the repo (issue #1479).
# When committed they appear as gitlinks (mode 160000) with no .gitmodules
# entry, which makes `git submodule status` fail and spams every CI job.
.claude/worktrees/