<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow the app to make network requests for card data and AI services -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow the app to accept incoming connections for multiplayer -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Disable App Sandbox for full desktop functionality -->
  <key>com.apple.security.app-sandbox</key>
  <false/>

  <!-- Allow the app to access local storage for user data -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow the app to access downloads folder -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>
</dict>
</plist>
