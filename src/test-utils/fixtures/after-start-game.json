{
  "description": "Game state after startGame is called",
  "category": "game_flow",
  "setup": {
    "playerNames": ["Alice", "Bob"],
    "startingLife": 20,
    "isCommander": false,
    "actions": ["startGame"]
  },
  "assertions": [
    { "path": "status", "operator": "toBe", "value": "in_progress" },
    { "path": "turn.turnNumber", "operator": "toBe", "value": 1 },
    { "path": "turn.isFirstTurn", "operator": "toBe", "value": true },
    { "path": "priorityPlayerId", "operator": "toBeDefined" },
    { "path": "consecutivePasses", "operator": "toBe", "value": 0 }
  ]
}
